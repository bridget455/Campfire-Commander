package com.bridget.campsitecommander

/**
 * GearData - Singleton object that stores all gear data using parallel arrays.
 * Uses parallel arrays: itemNames, categories, quantities, comments.
 * Each index across all arrays represents one gear item.
 */

    // Parallel arrays to store gear details
    val itemNames  = mutableListOf("Tent", "Marshmallows", "Flashlight", "First Aid Kit", "Water Bottle")
    val categories = mutableListOf("Shelter", "Food", "Safety", "First Aid", "Cooking")
    val quantities = mutableListOf(1, 3, 2, 1, 4)
    val comments   = mutableListOf(
        "4-person waterproof",
        "For S'mores (Mega size)",
        "Check batteries (AA)",
        "Check expiry dates",
        "BPA-free, 1L each"
    )

    /**
     * Adds a new gear item to all parallel arrays simultaneously.
     */
    fun addItem(name: String, category: String, qty: Int, comment: String) {
        itemNames.add(name)
        categories.add(category)
        quantities.add(qty)
        comments.add(comment)
        android.util.Log.d("GearData", "Item added: $name | Category: $category | Qty: $qty")
    }

    /**
     * Calculates total number of individual items packed using a loop.
     */
    fun getTotalItemsPacked(): Int {
        var total = 0
        for (qty in quantities) {
            total += qty
        }
        android.util.Log.d("GearData", "Total items packed: $total")
        return total
    }

    /**
     * Returns the number of unique gear entries.
     */
    fun getItemCount(): Int = itemNames.size
}

