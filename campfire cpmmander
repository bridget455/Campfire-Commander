package com.bridget.campfirecommander

import android.os.Bundle
import android.widget.ArrayAdapter
import android.widget.Button
import android.widget.EditText
import android.widget.Spinner
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity

/**
 * AddGearActivity - Allows users to add new camping gear.
 * Captures Item Name, Category, Quantity, and Comments.
 * Uses input validation for error handling.
 */
class AddGearActivity : AppCompatActivity() {

    private lateinit var etItemName: EditText
    private lateinit var spinnerCategory: Spinner
    private lateinit var etQuantity: EditText
    private lateinit var etComments: EditText
    private lateinit var btnSaveGear: Button
    private lateinit var btnBack: Button

    private val categories = arrayOf(
        "Shelter", "Food", "Safety",
        "First Aid", "Cooking", "Navigation",
        "Clothing", "Other"
    )

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_add_gear)

        android.util.Log.i("AddGearActivity", "AddGearActivity created")

        etItemName      = findViewById(R.id.etItemName)
        spinnerCategory = findViewById(R.id.spinnerCategory)
        etQuantity      = findViewById(R.id.etQuantity)
        etComments      = findViewById(R.id.etComments)
        btnSaveGear     = findViewById(R.id.btnSaveGear)
        btnBack         = findViewById(R.id.btnBackFromAdd)

        // Set up category spinner
        val adapter = ArrayAdapter(this, android.R.layout.simple_spinner_item, categories)
        adapter.setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
        spinnerCategory.adapter = adapter

        btnSaveGear.setOnClickListener {
            saveGearItem()
        }

        btnBack.setOnClickListener {
            android.util.Log.d("AddGearActivity", "Back button clicked")
            finish()
        }
    }

    /**
     * Validates user input and saves the new gear item.
     * Provides error feedback for incorrect input.
     */
    private fun saveGearItem() {
        val name    = etItemName.text.toString().trim()
        val category = spinnerCategory.selectedItem.toString()
        val qtyStr  = etQuantity.text.toString().trim()
        val comment = etComments.text.toString().trim()

        // Input validation
        if (name.isEmpty()) {
            etItemName.error = "Please enter an item name"
            android.util.Log.w("AddGearActivity", "Validation failed: empty name")
            return
        }

        if (qtyStr.isEmpty()) {
            etQuantity.error = "Please enter a quantity"
            android.util.Log.w("AddGearActivity", "Validation failed: empty quantity")
            return
        }

        val qty = qtyStr.toIntOrNull()
        if (qty == null || qty <= 0) {
            etQuantity.error = "Quantity must be a positive number"
            android.util.Log.w("AddGearActivity", "Validation failed: invalid quantity")
            return
        }

        // Save to parallel arrays
        GearData.addItem(name, category, qty, comment.ifEmpty { "No notes" })

        android.util.Log.i("AddGearActivity", "Gear saved: $name")
        Toast.makeText(this, "'$name' added to your pack!", Toast.LENGTH_SHORT).show()

        // Clear fields
        etItemName.text.clear()
        etQuantity.text.clear()
        etComments.text.clear()
        spinnerCategory.setSelection(0)
    }
}

