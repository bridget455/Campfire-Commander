package com.bridget.campfirecommander

import android.content.Intent
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import com.bridget.campsitecommander.GearData

/**
 *MainActivity-The main hub of the Campsite Commander app.
 *Display total items packed(Calculated via loop in GearData)
 *Provides navigation to Add Gear and detailed view screens
 */
class MainActivity:AppCompatActivity() {

    private lateinit var tvTotalItems:TextView
    private lateinit var btnAddGear:Button
    private lateinit var btnViewGear:Button

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        android.util.Log.i("MainActivity", "MainActivity created")

        //Bind views
        tvTotalItems = findViewById(R.id.tvTotalItems)
        btnAddGear = findViewById(R.id.btnAddGear)
        btnViewGear = findViewById(R.id.btnViewGear)

        btnAddGear.setOnClickListener {
            android.util.Log.d("MainActivity", "Add Gear button clicked")
            startActivity(Intent(this, AddGearActivity::class.java))
        }
    }



    override fun onResume() {
        super.onResume()
        val total = GearData.getTotalItemsPacked()
        tvTotalItems.text = "Total Items Packed:"
        total" android.util.Log.i(MainActivity", "Totalitemsdisplayed:
        total")
    }
}

